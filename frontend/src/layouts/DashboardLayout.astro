---
import Layout from './Layout.astro';

interface Props {
  title?: string;
  active?: string;
}

const { title = 'Panel · Sistema Educativo', active = 'inicio' } = Astro.props;

const menu = [
  { id: 'inicio',        label: 'Inicio',         icon: 'fa-house',            href: '/dashboard' },
  { id: 'alumnos',       label: 'Alumnos',        icon: 'fa-user-graduate',    href: '/alumnos' },
  { id: 'notas',         label: 'Notas',          icon: 'fa-clipboard-list',   href: '/notas' },
  { id: 'boletas',       label: 'Boletas',        icon: 'fa-file-lines',       href: '/boletas' },
  { id: 'comportamiento',label: 'Comportamiento', icon: 'fa-star',             href: '/comportamiento' },
  { id: 'materias',      label: 'Materias',       icon: 'fa-book',             href: '/materias' },
  { id: 'secciones',     label: 'Secciones',      icon: 'fa-layer-group',      href: '/secciones' },
  { id: 'maestros',      label: 'Maestros',       icon: 'fa-chalkboard-user',  href: '/maestros' },
];
---

<Layout title={title}>
  <div class="flex min-h-screen">
    <!-- Sidebar -->
    <aside class="hidden w-64 shrink-0 flex-col bg-navy-800 text-navy-100 md:flex">
      <div class="flex items-center gap-3 border-b border-navy-700 px-5 py-4">
        <div class="h-10 w-10 shrink-0 overflow-hidden rounded-full bg-white">
          <img
            src="/logo.png"
            alt="Logo"
            class="h-full w-full object-contain p-0.5"
          />
        </div>
        <div class="leading-tight">
          <p class="text-sm font-bold text-white">Sistema Educativo</p>
          <p class="text-[11px] text-navy-300">Guillermo Paz Andrade</p>
        </div>
      </div>

      <nav class="flex-1 space-y-1 px-3 py-4">
        {menu.map((item) => (
          <a
            href={item.href}
            class={`flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium transition ${
              active === item.id
                ? 'bg-navy-600 text-white'
                : 'text-navy-200 hover:bg-navy-700 hover:text-white'
            }`}
          >
            <i class={`fa-solid ${item.icon} w-5 text-center`}></i>
            {item.label}
          </a>
        ))}
      </nav>

      <div class="border-t border-navy-700 px-3 py-4">
        <button
          id="btn-cerrar-sesion"
          class="flex w-full items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium text-navy-200 transition hover:bg-navy-700 hover:text-white"
        >
          <i class="fa-solid fa-right-from-bracket w-5 text-center"></i>
          Cerrar sesión
        </button>
      </div>
    </aside>

    <!-- Contenido -->
    <div class="flex flex-1 flex-col">
      <!-- Topbar -->
      <header class="flex items-center justify-between border-b border-navy-200 bg-white px-6 py-3.5">
        <div class="flex items-center gap-3">
          <i class="fa-solid fa-graduation-cap text-navy-700 md:hidden"></i>
          <h1 class="text-base font-semibold text-navy-800">
            <slot name="title">Panel</slot>
          </h1>
        </div>
        <div class="flex items-center gap-3">
          <div class="hidden text-right sm:block">
            <p id="usuario-nombre" class="text-sm font-semibold leading-tight text-navy-800"></p>
            <p id="usuario-cargo" class="text-xs leading-tight text-navy-400"></p>
          </div>

          <div class="relative">
            <button
              id="btn-avatar"
              type="button"
              title="Cambiar foto de perfil"
              class="group relative h-9 w-9 shrink-0 overflow-hidden rounded-full bg-navy-700"
            >
              <span id="usuario-iniciales" class="absolute inset-0 flex items-center justify-center text-sm font-semibold text-white"></span>
              <img id="usuario-foto" alt="Foto de perfil" class="absolute inset-0 hidden h-full w-full object-cover" />
              <span class="absolute inset-0 hidden items-center justify-center bg-navy-900/50 text-white group-hover:flex">
                <i class="fa-solid fa-camera text-xs"></i>
              </span>
            </button>

            <div id="menu-avatar" class="absolute right-0 top-11 z-20 hidden w-44 overflow-hidden rounded-lg border border-navy-100 bg-white py-1 shadow-lg">
              <button id="btn-cambiar-foto" type="button" class="flex w-full items-center gap-2 px-3 py-2 text-left text-sm text-navy-700 hover:bg-navy-50">
                <i class="fa-solid fa-camera w-4 text-center"></i> Cambiar foto
              </button>
              <button id="btn-quitar-foto" type="button" class="hidden w-full items-center gap-2 px-3 py-2 text-left text-sm text-rose-600 hover:bg-rose-50">
                <i class="fa-solid fa-trash w-4 text-center"></i> Quitar foto
              </button>
            </div>

            <input id="input-foto" type="file" accept="image/*" class="hidden" />
          </div>
        </div>
      </header>

      <main class="flex-1 p-6">
        <slot />
      </main>
    </div>
  </div>
</Layout>

<script>
  import { requireAuth, getUsuario, actualizarUsuario, apiFetch, cerrarSesion } from '../lib/auth.js';

  requireAuth();

  const $ = (id) => document.getElementById(id);
  const fotoImg = $('usuario-foto');
  const btnQuitar = $('btn-quitar-foto');

  function pintarUsuario(usuario) {
    if (!usuario) return;

    $('usuario-nombre').textContent = usuario.nombre;
    $('usuario-cargo').textContent = usuario.cargo ?? '';
    $('usuario-iniciales').textContent = usuario.nombre
      .split(' ')
      .slice(0, 2)
      .map((p) => p[0])
      .join('')
      .toUpperCase();

    if (usuario.foto_url) {
      fotoImg.src = usuario.foto_url;
      fotoImg.classList.remove('hidden');
      btnQuitar.classList.remove('hidden');
      btnQuitar.classList.add('flex');
    } else {
      fotoImg.removeAttribute('src');
      fotoImg.classList.add('hidden');
      btnQuitar.classList.add('hidden');
      btnQuitar.classList.remove('flex');
    }
  }

  pintarUsuario(getUsuario());

  document.getElementById('btn-cerrar-sesion')?.addEventListener('click', cerrarSesion);

  // --- Menú de la foto (cambiar / quitar) ---
  const menu = $('menu-avatar');
  $('btn-avatar').addEventListener('click', (e) => {
    e.stopPropagation();
    menu.classList.toggle('hidden');
  });
  document.addEventListener('click', () => menu.classList.add('hidden'));

  const inputFoto = $('input-foto');
  $('btn-cambiar-foto').addEventListener('click', () => {
    menu.classList.add('hidden');
    inputFoto.click();
  });

  inputFoto.addEventListener('change', async () => {
    const archivo = inputFoto.files[0];
    if (!archivo) return;

    const datos = new FormData();
    datos.append('foto', archivo);

    const res = await apiFetch('/perfil/foto', { method: 'POST', body: datos });
    inputFoto.value = '';

    if (res.ok) {
      const data = await res.json();
      pintarUsuario(actualizarUsuario({ foto_url: data.foto_url }));
    } else {
      alert('No se pudo subir la foto. Verifica que sea una imagen de menos de 3 MB.');
    }
  });

  btnQuitar.addEventListener('click', async () => {
    menu.classList.add('hidden');
    await apiFetch('/perfil/foto', { method: 'DELETE' });
    pintarUsuario(actualizarUsuario({ foto_url: null }));
  });
</script>
