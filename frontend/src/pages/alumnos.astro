---
import DashboardLayout from '../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Alumnos · Sistema Educativo" active="alumnos">
  <span slot="title">Alumnos</span>

  <!-- Encabezado de la sección -->
  <div class="mb-6 flex flex-wrap items-center justify-between gap-3">
    <div>
      <h2 class="text-lg font-bold text-navy-800">Listado de alumnos</h2>
      <p class="text-sm text-navy-500">
        <span id="contador">0</span> alumnos registrados
      </p>
    </div>
    <button
      id="btn-nuevo"
      class="flex items-center gap-2 rounded-lg bg-navy-700 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-navy-800"
    >
      <i class="fa-solid fa-user-plus"></i>
      Nuevo alumno
    </button>
  </div>

  <!-- Filtros -->
  <div class="mb-4 flex flex-wrap gap-3">
    <div class="relative flex-1 min-w-[220px]">
      <i class="fa-solid fa-magnifying-glass pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 text-navy-400"></i>
      <input
        id="buscar"
        type="text"
        placeholder="Buscar por nombre o código..."
        class="w-full rounded-lg border border-navy-200 bg-white py-2.5 pl-10 pr-3 text-sm outline-none transition focus:border-navy-500 focus:ring-2 focus:ring-navy-200"
      />
    </div>
    <select
      id="filtro-seccion"
      class="rounded-lg border border-navy-200 bg-white px-3 py-2.5 text-sm text-navy-700 outline-none transition focus:border-navy-500 focus:ring-2 focus:ring-navy-200"
    >
      <option value="">Todas las secciones</option>
    </select>
  </div>

  <!-- Tabla -->
  <div class="overflow-hidden rounded-xl border border-navy-100 bg-white">
    <table class="w-full text-left text-sm">
      <thead class="bg-navy-50 text-xs uppercase tracking-wide text-navy-500">
        <tr>
          <th class="px-4 py-3 font-semibold">Alumno</th>
          <th class="px-4 py-3 font-semibold">Código</th>
          <th class="px-4 py-3 font-semibold">Grado / Sección</th>
          <th class="px-4 py-3 font-semibold">Sexo</th>
          <th class="px-4 py-3 font-semibold">Edad</th>
          <th class="px-4 py-3 text-right font-semibold">Acciones</th>
        </tr>
      </thead>
      <tbody id="tabla-alumnos" class="divide-y divide-navy-100">
        <!-- filas dinámicas -->
      </tbody>
    </table>
    <div id="vacio" class="hidden px-4 py-12 text-center text-navy-400">
      <i class="fa-solid fa-inbox mb-2 text-3xl"></i>
      <p class="text-sm">No hay alumnos que coincidan.</p>
    </div>
    <div id="cargando" class="px-4 py-12 text-center text-navy-400">
      <i class="fa-solid fa-spinner fa-spin mb-2 text-2xl"></i>
      <p class="text-sm">Cargando...</p>
    </div>
  </div>

  <!-- Modal de alta/edición -->
  <div id="modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-navy-900/50 p-4">
    <div class="w-full max-w-lg rounded-2xl bg-white shadow-2xl">
      <div class="flex items-center justify-between border-b border-navy-100 px-6 py-4">
        <h3 id="modal-titulo" class="text-base font-semibold text-navy-800">Nuevo alumno</h3>
        <button id="btn-cerrar" class="text-navy-400 transition hover:text-navy-700">
          <i class="fa-solid fa-xmark text-lg"></i>
        </button>
      </div>

      <form id="form-alumno" class="space-y-4 px-6 py-5">
        <input type="hidden" id="f-id" />

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="mb-1 block text-sm font-medium text-navy-700">Nombres</label>
            <input id="f-nombres" type="text" required
              class="w-full rounded-lg border border-navy-200 px-3 py-2 text-sm outline-none focus:border-navy-500 focus:ring-2 focus:ring-navy-200" />
          </div>
          <div>
            <label class="mb-1 block text-sm font-medium text-navy-700">Apellidos</label>
            <input id="f-apellidos" type="text" required
              class="w-full rounded-lg border border-navy-200 px-3 py-2 text-sm outline-none focus:border-navy-500 focus:ring-2 focus:ring-navy-200" />
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="mb-1 block text-sm font-medium text-navy-700">Código</label>
            <input id="f-codigo" type="text" required
              class="w-full rounded-lg border border-navy-200 px-3 py-2 text-sm outline-none focus:border-navy-500 focus:ring-2 focus:ring-navy-200" />
          </div>
          <div>
            <label class="mb-1 block text-sm font-medium text-navy-700">Sección</label>
            <select id="f-seccion" required
              class="w-full rounded-lg border border-navy-200 px-3 py-2 text-sm text-navy-700 outline-none focus:border-navy-500 focus:ring-2 focus:ring-navy-200">
            </select>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="mb-1 block text-sm font-medium text-navy-700">Sexo</label>
            <select id="f-sexo"
              class="w-full rounded-lg border border-navy-200 px-3 py-2 text-sm text-navy-700 outline-none focus:border-navy-500 focus:ring-2 focus:ring-navy-200">
              <option value="">—</option>
              <option value="M">Masculino</option>
              <option value="F">Femenino</option>
            </select>
          </div>
          <div>
            <label class="mb-1 block text-sm font-medium text-navy-700">Fecha de nacimiento</label>
            <input id="f-fecha" type="date"
              class="w-full rounded-lg border border-navy-200 px-3 py-2 text-sm text-navy-700 outline-none focus:border-navy-500 focus:ring-2 focus:ring-navy-200" />
          </div>
        </div>

        <p id="form-error" class="hidden rounded-lg bg-rose-50 px-3 py-2 text-sm text-rose-700"></p>

        <div class="flex justify-end gap-3 pt-2">
          <button type="button" id="btn-cancelar"
            class="rounded-lg border border-navy-200 px-4 py-2 text-sm font-medium text-navy-700 transition hover:bg-navy-50">
            Cancelar
          </button>
          <button type="submit"
            class="flex items-center gap-2 rounded-lg bg-navy-700 px-4 py-2 text-sm font-semibold text-white transition hover:bg-navy-800">
            <i class="fa-solid fa-floppy-disk"></i>
            Guardar
          </button>
        </div>
      </form>
    </div>
  </div>
</DashboardLayout>

<script>
  const API = 'http://localhost:8000/api';

  const $ = (id) => document.getElementById(id);
  const tabla = $('tabla-alumnos');
  const modal = $('modal');

  let secciones = [];

  // --- Utilidades ---
  function iniciales(nombres, apellidos) {
    return ((nombres?.[0] ?? '') + (apellidos?.[0] ?? '')).toUpperCase();
  }

  function badgeSexo(sexo) {
    if (sexo === 'M') return '<span class="rounded-full bg-blue-100 px-2 py-0.5 text-xs font-medium text-blue-700">Masculino</span>';
    if (sexo === 'F') return '<span class="rounded-full bg-rose-100 px-2 py-0.5 text-xs font-medium text-rose-700">Femenino</span>';
    return '<span class="text-navy-300">—</span>';
  }

  // --- Cargar secciones (filtro + formulario) ---
  async function cargarSecciones() {
    const res = await fetch(`${API}/secciones`);
    secciones = await res.json();

    const opciones = secciones
      .map((s) => `<option value="${s.id}">${s.grado.nombre} "${s.nombre}"</option>`)
      .join('');

    $('filtro-seccion').insertAdjacentHTML('beforeend', opciones);
    $('f-seccion').innerHTML = '<option value="">Seleccionar...</option>' + opciones;
  }

  // --- Cargar alumnos ---
  async function cargarAlumnos() {
    $('cargando').classList.remove('hidden');
    $('vacio').classList.add('hidden');

    const params = new URLSearchParams();
    if ($('buscar').value) params.set('buscar', $('buscar').value);
    if ($('filtro-seccion').value) params.set('seccion_id', $('filtro-seccion').value);

    const res = await fetch(`${API}/alumnos?${params}`);
    const alumnos = await res.json();

    $('cargando').classList.add('hidden');
    $('contador').textContent = alumnos.length;
    tabla.innerHTML = '';

    if (alumnos.length === 0) {
      $('vacio').classList.remove('hidden');
      return;
    }

    for (const a of alumnos) {
      const grado = a.seccion ? `${a.seccion.grado.nombre} "${a.seccion.nombre}"` : '—';
      const fila = document.createElement('tr');
      fila.className = 'transition hover:bg-navy-50';
      fila.innerHTML = `
        <td class="px-4 py-3">
          <div class="flex items-center gap-3">
            <div class="flex h-9 w-9 items-center justify-center rounded-full bg-navy-700 text-xs font-bold text-white">
              ${iniciales(a.nombres, a.apellidos)}
            </div>
            <span class="font-medium text-navy-800">${a.nombre_completo}</span>
          </div>
        </td>
        <td class="px-4 py-3 font-mono text-xs text-navy-500">${a.codigo}</td>
        <td class="px-4 py-3 text-navy-600">${grado}</td>
        <td class="px-4 py-3">${badgeSexo(a.sexo)}</td>
        <td class="px-4 py-3 text-navy-600">${a.edad != null ? a.edad + ' años' : '—'}</td>
        <td class="px-4 py-3">
          <div class="flex justify-end gap-1">
            <button data-accion="editar" data-id="${a.id}"
              class="flex h-8 w-8 items-center justify-center rounded-lg text-navy-500 transition hover:bg-navy-100 hover:text-navy-700" title="Editar">
              <i class="fa-solid fa-pen pointer-events-none"></i>
            </button>
            <button data-accion="eliminar" data-id="${a.id}"
              class="flex h-8 w-8 items-center justify-center rounded-lg text-rose-500 transition hover:bg-rose-50" title="Eliminar">
              <i class="fa-solid fa-trash pointer-events-none"></i>
            </button>
          </div>
        </td>`;
      tabla.appendChild(fila);
    }
  }

  // --- Modal ---
  function abrirModal(alumno = null) {
    $('form-error').classList.add('hidden');
    $('form-alumno').reset();

    if (alumno) {
      $('modal-titulo').textContent = 'Editar alumno';
      $('f-id').value = alumno.id;
      $('f-nombres').value = alumno.nombres;
      $('f-apellidos').value = alumno.apellidos;
      $('f-codigo').value = alumno.codigo;
      $('f-seccion').value = alumno.seccion_id;
      $('f-sexo').value = alumno.sexo ?? '';
      $('f-fecha').value = alumno.fecha_nacimiento ? alumno.fecha_nacimiento.substring(0, 10) : '';
    } else {
      $('modal-titulo').textContent = 'Nuevo alumno';
      $('f-id').value = '';
    }

    modal.classList.remove('hidden');
    modal.classList.add('flex');
  }

  function cerrarModal() {
    modal.classList.add('hidden');
    modal.classList.remove('flex');
  }

  // --- Guardar (crear o actualizar) ---
  async function guardar(e) {
    e.preventDefault();
    $('form-error').classList.add('hidden');

    const id = $('f-id').value;
    const datos = {
      nombres: $('f-nombres').value,
      apellidos: $('f-apellidos').value,
      codigo: $('f-codigo').value,
      seccion_id: $('f-seccion').value,
      sexo: $('f-sexo').value || null,
      fecha_nacimiento: $('f-fecha').value || null,
    };

    const url = id ? `${API}/alumnos/${id}` : `${API}/alumnos`;
    const metodo = id ? 'PUT' : 'POST';

    const res = await fetch(url, {
      method: metodo,
      headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
      body: JSON.stringify(datos),
    });

    if (res.ok) {
      cerrarModal();
      cargarAlumnos();
    } else if (res.status === 422) {
      const err = await res.json();
      const msg = Object.values(err.errors).flat().join(' ');
      $('form-error').textContent = msg;
      $('form-error').classList.remove('hidden');
    } else {
      $('form-error').textContent = 'Ocurrió un error al guardar.';
      $('form-error').classList.remove('hidden');
    }
  }

  // --- Eliminar ---
  async function eliminar(id) {
    if (!confirm('¿Eliminar este alumno? Esta acción no se puede deshacer.')) return;
    await fetch(`${API}/alumnos/${id}`, { method: 'DELETE' });
    cargarAlumnos();
  }

  // --- Eventos ---
  $('btn-nuevo').addEventListener('click', () => abrirModal());
  $('btn-cerrar').addEventListener('click', cerrarModal);
  $('btn-cancelar').addEventListener('click', cerrarModal);
  $('form-alumno').addEventListener('submit', guardar);
  $('buscar').addEventListener('input', cargarAlumnos);
  $('filtro-seccion').addEventListener('change', cargarAlumnos);
  modal.addEventListener('click', (e) => { if (e.target === modal) cerrarModal(); });

  tabla.addEventListener('click', async (e) => {
    const btn = e.target.closest('button[data-accion]');
    if (!btn) return;
    const id = btn.dataset.id;
    if (btn.dataset.accion === 'eliminar') {
      eliminar(id);
    } else if (btn.dataset.accion === 'editar') {
      const res = await fetch(`${API}/alumnos/${id}`);
      abrirModal(await res.json());
    }
  });

  // --- Inicio ---
  cargarSecciones().then(cargarAlumnos);
</script>
