---
import DashboardLayout from '../layouts/DashboardLayout.astro';

// Datos de ejemplo (se conectarán a la API de Laravel más adelante)
const stats = [
  { label: 'Alumnos',   value: '—', icon: 'fa-user-graduate',   href: '/alumnos' },
  { label: 'Secciones', value: '—', icon: 'fa-layer-group',     href: '/secciones' },
  { label: 'Materias',  value: '8', icon: 'fa-book',            href: '/materias' },
  { label: 'Maestros',  value: '—', icon: 'fa-chalkboard-user', href: '/maestros' },
];

const accesos = [
  { label: 'Registrar alumno', desc: 'Inscribir un nuevo estudiante', icon: 'fa-user-plus', href: '/alumnos' },
  { label: 'Ingresar notas',   desc: 'Zona y examen por unidad',      icon: 'fa-pen-to-square', href: '/notas' },
  { label: 'Comportamiento',   desc: 'Registrar conducta',            icon: 'fa-star', href: '/comportamiento' },
];
---

<DashboardLayout title="Inicio · Sistema Educativo" active="inicio">
  <span slot="title">Inicio</span>

  <!-- Bienvenida -->
  <div class="mb-6 rounded-2xl bg-navy-700 p-6 text-white">
    <h2 class="text-xl font-bold">Bienvenido al Sistema Educativo</h2>
    <p class="mt-1 text-sm text-navy-200">
      Gestión de notas, exámenes, zona y comportamiento de los alumnos.
    </p>
  </div>

  <!-- Tarjetas de resumen -->
  <div class="mb-8 grid grid-cols-2 gap-4 lg:grid-cols-4">
    {stats.map((s) => (
      <a
        href={s.href}
        class="flex items-center gap-4 rounded-xl border border-navy-100 bg-white p-5 transition hover:border-navy-300 hover:shadow-md"
      >
        <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-navy-50 text-xl text-navy-700">
          <i class={`fa-solid ${s.icon}`}></i>
        </div>
        <div>
          <p class="text-2xl font-bold text-navy-800">{s.value}</p>
          <p class="text-sm text-navy-500">{s.label}</p>
        </div>
      </a>
    ))}
  </div>

  <!-- Accesos rápidos -->
  <h3 class="mb-3 text-sm font-semibold uppercase tracking-wide text-navy-500">
    Accesos rápidos
  </h3>
  <div class="grid gap-4 md:grid-cols-3">
    {accesos.map((a) => (
      <a
        href={a.href}
        class="group rounded-xl border border-navy-100 bg-white p-5 transition hover:border-navy-300 hover:shadow-md"
      >
        <div class="mb-3 flex h-11 w-11 items-center justify-center rounded-lg bg-navy-700 text-lg text-white transition group-hover:bg-navy-800">
          <i class={`fa-solid ${a.icon}`}></i>
        </div>
        <p class="font-semibold text-navy-800">{a.label}</p>
        <p class="text-sm text-navy-500">{a.desc}</p>
      </a>
    ))}
  </div>
</DashboardLayout>
