---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Ingresar · Sistema Educativo">
  <main class="flex min-h-screen items-center justify-center bg-navy-700 px-4 py-10">
    <div class="w-full max-w-md">
      <!-- Encabezado / escuela -->
      <div class="mb-8 text-center">
        <div class="mx-auto mb-4 h-32 w-32 overflow-hidden rounded-full bg-white shadow-lg">
          <img
            src="/logo.png"
            alt="Logo de la escuela"
            class="h-full w-full object-contain p-1.5"
          />
        </div>
        <h1 class="text-lg font-bold leading-tight text-white">
          Escuela Oficial Urbana Mixta No. 1
        </h1>
        <p class="text-sm font-medium text-navy-200">"Dr. Guillermo Paz Andrade"</p>
        <p class="mt-1 text-xs text-navy-300">Ciudad Tecún Umán</p>
      </div>

      <!-- Tarjeta de login -->
      <div class="rounded-2xl bg-white p-8 shadow-xl">
        <h2 class="mb-6 text-center text-xl font-semibold text-navy-800">
          Iniciar sesión
        </h2>

        <form id="form-login" class="space-y-5">
          <!-- Correo -->
          <div>
            <label for="email" class="mb-1.5 block text-sm font-medium text-navy-700">
              Correo electrónico
            </label>
            <div class="relative">
              <i class="fa-solid fa-envelope pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 text-navy-400"></i>
              <input
                id="email"
                name="email"
                type="email"
                required
                placeholder="usuario@escuela.edu.gt"
                class="w-full rounded-lg border border-navy-200 bg-navy-50 py-2.5 pl-10 pr-3 text-sm text-navy-900 outline-none transition focus:border-navy-500 focus:bg-white focus:ring-2 focus:ring-navy-200"
              />
            </div>
          </div>

          <!-- Contraseña -->
          <div>
            <label for="password" class="mb-1.5 block text-sm font-medium text-navy-700">
              Contraseña
            </label>
            <div class="relative">
              <i class="fa-solid fa-lock pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 text-navy-400"></i>
              <input
                id="password"
                name="password"
                type="password"
                required
                placeholder="••••••••"
                class="w-full rounded-lg border border-navy-200 bg-navy-50 py-2.5 pl-10 pr-10 text-sm text-navy-900 outline-none transition focus:border-navy-500 focus:bg-white focus:ring-2 focus:ring-navy-200"
              />
              <button
                type="button"
                id="toggle-password"
                aria-label="Mostrar u ocultar contraseña"
                class="absolute right-3 top-1/2 -translate-y-1/2 text-navy-400 transition hover:text-navy-700"
              >
                <i id="toggle-icon" class="fa-solid fa-eye"></i>
              </button>
            </div>
          </div>

          <label class="flex cursor-pointer items-center gap-2 text-sm text-navy-700 select-none">
            <input id="recordar" type="checkbox" class="h-4 w-4 rounded border-navy-300 text-navy-700 accent-navy-700" />
            Recordar usuario
          </label>

          <p id="form-error" class="hidden rounded-lg bg-rose-50 px-3 py-2 text-sm text-rose-700"></p>

          <button
            type="submit"
            class="flex w-full items-center justify-center gap-2 rounded-lg bg-navy-700 py-2.5 text-sm font-semibold text-white transition hover:bg-navy-800"
          >
            <i class="fa-solid fa-right-to-bracket"></i>
            Ingresar
          </button>
        </form>
      </div>

      <p class="mt-6 text-center text-xs text-navy-300">
        Sistema de gestión académica &middot; {new Date().getFullYear()}
      </p>
    </div>
  </main>
</Layout>

<script>
  import { setSesion, getToken } from '../lib/auth.js';

  // Si ya hay sesión activa, no mostrar el login
  if (getToken()) window.location.href = '/dashboard';

  const btn = document.getElementById('toggle-password');
  const input = document.getElementById('password');
  const icon = document.getElementById('toggle-icon');

  btn?.addEventListener('click', () => {
    const oculto = input.type === 'password';
    input.type = oculto ? 'text' : 'password';
    icon.classList.toggle('fa-eye', !oculto);
    icon.classList.toggle('fa-eye-slash', oculto);
  });

  // Recordar usuario: precargar el correo guardado
  const email = document.getElementById('email');
  const recordar = document.getElementById('recordar');
  const guardado = localStorage.getItem('recordar_email');
  if (guardado) {
    email.value = guardado;
    recordar.checked = true;
  }

  // Iniciar sesión contra la API
  const form = document.getElementById('form-login');
  const errorEl = document.getElementById('form-error');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorEl.classList.add('hidden');

    if (recordar.checked) localStorage.setItem('recordar_email', email.value);
    else localStorage.removeItem('recordar_email');

    const submitBtn = form.querySelector('button[type="submit"]');

    try {
      const res = await fetch('http://localhost:8000/api/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify({ email: email.value, password: input.value }),
      });

      if (!res.ok) {
        const data = await res.json().catch(() => ({}));
        const msg = data.errors ? Object.values(data.errors).flat().join(' ') : (data.message ?? 'No se pudo iniciar sesión.');
        errorEl.textContent = msg;
        errorEl.classList.remove('hidden');
        if (submitBtn) { submitBtn.disabled = false; }
        return;
      }

      const data = await res.json();
      setSesion(data.token, data.usuario);
      window.location.href = '/dashboard';
    } catch {
      errorEl.textContent = 'No se pudo conectar con el servidor.';
      errorEl.classList.remove('hidden');
      if (submitBtn) { submitBtn.disabled = false; }
    }
  });
</script>
