---
import DashboardLayout from '../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Notas · Sistema Educativo" active="notas">
  <span slot="title">Notas</span>

  <div class="mb-6">
    <h2 class="text-lg font-bold text-navy-800">Ingreso de notas</h2>
    <p class="text-sm text-navy-500">
      Captura el punteo de cada alumno en Tareas, Trabajos, Actividades y Cuaderno (suman la zona),
      más el examen. Zona sobre 60, examen sobre 40 — aprueba con 60.
    </p>
  </div>

  <!-- Filtros -->
  <div class="mb-5 grid gap-3 rounded-xl border border-navy-100 bg-white p-4 sm:grid-cols-2 lg:grid-cols-4">
    <div>
      <label class="mb-1 block text-xs font-semibold uppercase tracking-wide text-navy-500">Sección</label>
      <select id="f-seccion" class="w-full rounded-lg border border-navy-200 px-3 py-2 text-sm text-navy-700 outline-none focus:border-navy-500 focus:ring-2 focus:ring-navy-200">
        <option value="">Seleccionar...</option>
      </select>
    </div>
    <div>
      <label class="mb-1 block text-xs font-semibold uppercase tracking-wide text-navy-500">Materia</label>
      <select id="f-materia" class="w-full rounded-lg border border-navy-200 px-3 py-2 text-sm text-navy-700 outline-none focus:border-navy-500 focus:ring-2 focus:ring-navy-200">
        <option value="">Seleccionar...</option>
      </select>
    </div>
    <div>
      <label class="mb-1 block text-xs font-semibold uppercase tracking-wide text-navy-500">Unidad</label>
      <select id="f-unidad" class="w-full rounded-lg border border-navy-200 px-3 py-2 text-sm text-navy-700 outline-none focus:border-navy-500 focus:ring-2 focus:ring-navy-200">
        <option value="1">Unidad 1</option>
        <option value="2">Unidad 2</option>
        <option value="3">Unidad 3</option>
        <option value="4">Unidad 4</option>
      </select>
    </div>
    <div class="flex items-end">
      <button id="btn-cargar" data-bloquear class="flex w-full items-center justify-center gap-2 rounded-lg bg-navy-700 px-4 py-2 text-sm font-semibold text-white transition hover:bg-navy-800">
        <i class="fa-solid fa-table-list"></i>
        Cargar planilla
      </button>
    </div>
  </div>

  <!-- Mensaje inicial -->
  <div id="mensaje" class="rounded-xl border border-dashed border-navy-200 bg-white px-4 py-16 text-center text-navy-400">
    <i class="fa-solid fa-clipboard-list mb-2 text-3xl"></i>
    <p class="text-sm">Elige los filtros y presiona "Cargar planilla".</p>
  </div>

  <!-- Planilla -->
  <div id="planilla" class="hidden">
    <div class="overflow-x-auto rounded-xl border border-navy-100 bg-white">
      <table class="w-full text-left text-sm">
        <thead class="bg-navy-50 text-xs uppercase tracking-wide text-navy-500">
          <tr id="cabecera">
            <th class="px-4 py-3 font-semibold">Alumno</th>
            <!-- columnas de actividades dinámicas -->
            <th class="px-3 py-3 font-semibold text-center">Zona<br /><span class="font-normal text-navy-400">/60</span></th>
            <th class="px-3 py-3 font-semibold text-center">Examen<br /><span class="font-normal text-navy-400">/40</span></th>
            <th class="px-3 py-3 font-semibold text-center">Total</th>
            <th class="px-3 py-3 font-semibold text-center">Estado</th>
          </tr>
        </thead>
        <tbody id="tabla-notas" class="divide-y divide-navy-100"></tbody>
      </table>
    </div>

    <div class="mt-4 flex flex-wrap items-center justify-between gap-3">
      <div class="flex gap-4 text-sm">
        <span class="text-navy-600"><i class="fa-solid fa-circle-check mr-1 text-emerald-500"></i> Aprobados: <b id="n-aprobados">0</b></span>
        <span class="text-navy-600"><i class="fa-solid fa-circle-xmark mr-1 text-rose-500"></i> Reprobados: <b id="n-reprobados">0</b></span>
      </div>
      <div class="flex items-center gap-3">
        <span id="guardado-msg" class="text-sm text-emerald-600"></span>
        <button id="btn-guardar" data-bloquear class="flex items-center gap-2 rounded-lg bg-navy-700 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-navy-800">
          <i class="fa-solid fa-floppy-disk"></i>
          Guardar notas
        </button>
      </div>
    </div>
  </div>
</DashboardLayout>

<script>
  import { apiFetch } from '../lib/auth.js';
  import { escapeHtml as esc } from '../lib/html.js';

  const $ = (id) => document.getElementById(id);
  const APROBADO = 60;

  let actividades = []; // [{id, nombre, punteo_max}]
  let alumnos = [];     // [{alumno_id, codigo, nombre_completo, examen, calificaciones:{actId:val}}]

  const ctx = () => ({
    seccion_id: Number($('f-seccion').value),
    materia_id: Number($('f-materia').value),
    unidad: Number($('f-unidad').value),
  });

  function fmt(n) {
    if (n === null || n === undefined || n === '') return '—';
    return Number(n).toFixed(2).replace(/\.00$/, '').replace(/(\.\d)0$/, '$1');
  }

  // --- Cargar selects ---
  async function cargarFiltros() {
    const [sec, mat] = await Promise.all([
      apiFetch('/secciones').then((r) => r.json()),
      apiFetch('/materias').then((r) => r.json()),
    ]);
    $('f-seccion').innerHTML =
      '<option value="">Seleccionar...</option>' +
      sec.map((s) => `<option value="${s.id}">${esc(s.grado.nombre)} "${esc(s.nombre)}"</option>`).join('');
    $('f-materia').innerHTML =
      '<option value="">Seleccionar...</option>' +
      mat.map((m) => `<option value="${m.id}">${esc(m.nombre)}</option>`).join('');
  }

  // --- Cargar planilla ---
  async function cargarPlanilla() {
    if (!$('f-seccion').value || !$('f-materia').value) {
      alert('Selecciona sección y materia.');
      return;
    }
    const params = new URLSearchParams(ctx());
    const data = await apiFetch(`/notas/planilla?${params}`).then((r) => r.json());

    actividades = data.actividades.map((a) => ({ id: a.id, nombre: a.nombre, punteo_max: Number(a.punteo_max) }));
    alumnos = data.alumnos.map((a) => ({
      alumno_id: a.alumno_id,
      codigo: a.codigo,
      nombre_completo: a.nombre_completo,
      examen: a.examen ?? '',
      calificaciones: { ...a.calificaciones },
    }));

    if (alumnos.length === 0) {
      $('planilla').classList.add('hidden');
      $('mensaje').classList.remove('hidden');
      $('mensaje').innerHTML = '<i class="fa-solid fa-inbox mb-2 text-3xl"></i><p class="text-sm">Esta sección no tiene alumnos.</p>';
      return;
    }

    $('mensaje').classList.add('hidden');
    $('planilla').classList.remove('hidden');
    render();
  }

  // --- Render completo de la tabla ---
  function render() {
    // Cabecera: insertar columnas de actividades antes de "Zona"
    const cab = $('cabecera');
    cab.querySelectorAll('.col-act').forEach((el) => el.remove());
    const refZona = cab.children[1]; // la celda "Zona"
    for (const act of actividades) {
      const th = document.createElement('th');
      th.className = 'col-act px-3 py-3 text-center font-semibold';
      th.innerHTML = `
        <div class="flex flex-col items-center">
          <span>${esc(act.nombre)}</span>
          <span class="font-normal text-navy-400">/${fmt(act.punteo_max)}</span>
        </div>`;
      cab.insertBefore(th, refZona);
    }

    // Cuerpo
    const tbody = $('tabla-notas');
    tbody.innerHTML = '';
    for (const a of alumnos) {
      const tr = document.createElement('tr');
      tr.className = 'hover:bg-navy-50';
      const inputCls = 'w-20 rounded-lg border border-navy-200 px-2 py-1.5 text-sm text-center outline-none focus:border-navy-500 focus:ring-2 focus:ring-navy-200';

      let celdasAct = '';
      for (const act of actividades) {
        const val = a.calificaciones[act.id] ?? '';
        celdasAct += `<td class="px-3 py-2 text-center">
          <input type="number" class="cal ${inputCls}" min="0" max="${act.punteo_max}" step="0.01"
            data-alumno="${a.alumno_id}" data-act="${act.id}" value="${esc(val)}" placeholder="0" />
        </td>`;
      }

      tr.innerHTML = `
        <td class="px-4 py-2.5 font-medium text-navy-800 whitespace-nowrap">
          ${esc(a.nombre_completo)}<span class="ml-1 font-mono text-xs text-navy-400">${esc(a.codigo)}</span>
        </td>
        ${celdasAct}
        <td id="zona-${a.alumno_id}" class="px-3 py-2 text-center font-semibold text-navy-700">—</td>
        <td class="px-3 py-2 text-center">
          <input type="number" class="examen ${inputCls}" min="0" max="40" step="0.01"
            data-alumno="${a.alumno_id}" value="${esc(a.examen)}" placeholder="0" />
        </td>
        <td id="total-${a.alumno_id}" class="px-3 py-2 text-center font-semibold text-navy-800">—</td>
        <td id="estado-${a.alumno_id}" class="px-3 py-2 text-center">—</td>`;
      tbody.appendChild(tr);
      recomputeRow(a);
    }

    actualizarResumen();
  }

  // --- Cálculo por alumno ---
  function calcZona(a) {
    let z = 0, hay = false;
    for (const act of actividades) {
      const v = parseFloat(a.calificaciones[act.id]);
      if (!isNaN(v)) { z += v; hay = true; }
    }
    return { zona: Math.min(z, 60), hay };
  }

  function recomputeRow(a) {
    const { zona, hay } = calcZona(a);
    const examen = parseFloat(a.examen);
    const hayExamen = !isNaN(examen);

    $(`zona-${a.alumno_id}`).textContent = hay ? fmt(zona) : '—';

    if (!hay && !hayExamen) {
      $(`total-${a.alumno_id}`).textContent = '—';
      $(`estado-${a.alumno_id}`).innerHTML = '<span class="text-navy-300">—</span>';
      return;
    }

    const total = zona + (hayExamen ? examen : 0);
    $(`total-${a.alumno_id}`).textContent = fmt(total);
    $(`estado-${a.alumno_id}`).innerHTML = total >= APROBADO
      ? '<span class="rounded-full bg-emerald-100 px-2.5 py-0.5 text-xs font-semibold text-emerald-700"><i class="fa-solid fa-check mr-1"></i>Aprobado</span>'
      : '<span class="rounded-full bg-rose-100 px-2.5 py-0.5 text-xs font-semibold text-rose-700"><i class="fa-solid fa-xmark mr-1"></i>Reprobado</span>';
  }

  function actualizarResumen() {
    let ap = 0, re = 0;
    for (const a of alumnos) {
      const { zona, hay } = calcZona(a);
      const examen = parseFloat(a.examen);
      if (!hay && isNaN(examen)) continue;
      const total = zona + (isNaN(examen) ? 0 : examen);
      if (total >= APROBADO) ap++; else re++;
    }
    $('n-aprobados').textContent = ap;
    $('n-reprobados').textContent = re;
  }

  // --- Guardar ---
  async function guardar() {
    const notas = alumnos.map((a) => ({
      alumno_id: a.alumno_id,
      examen: a.examen === '' ? null : Number(a.examen),
      calificaciones: Object.fromEntries(
        actividades.map((act) => [act.id, a.calificaciones[act.id] === '' || a.calificaciones[act.id] == null ? null : Number(a.calificaciones[act.id])])
      ),
    }));

    const res = await apiFetch('/notas/planilla', {
      method: 'POST',
      body: JSON.stringify({ ...ctx(), notas }),
    });

    const msg = $('guardado-msg');
    if (res.ok) {
      const data = await res.json();
      msg.className = 'text-sm text-emerald-600';
      msg.textContent = '✓ ' + data.mensaje;
      setTimeout(() => (msg.textContent = ''), 3500);
    } else {
      msg.className = 'text-sm text-rose-600';
      msg.textContent = 'Error al guardar.';
    }
  }

  // --- Eventos ---
  $('btn-cargar').addEventListener('click', cargarPlanilla);
  $('btn-guardar').addEventListener('click', guardar);

  // captura de notas (delegación en el cuerpo)
  $('tabla-notas').addEventListener('input', (e) => {
    const t = e.target;
    const alumnoId = Number(t.dataset.alumno);
    const a = alumnos.find((x) => x.alumno_id === alumnoId);
    if (!a) return;
    if (t.classList.contains('cal')) {
      a.calificaciones[Number(t.dataset.act)] = t.value;
    } else if (t.classList.contains('examen')) {
      a.examen = t.value;
    }
    recomputeRow(a);
    actualizarResumen();
  });

  cargarFiltros();
</script>
