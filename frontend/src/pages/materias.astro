---
import DashboardLayout from '../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Materias · Sistema Educativo" active="materias">
  <span slot="title">Materias</span>

  <div class="mb-6 flex flex-wrap items-center justify-between gap-3">
    <div>
      <h2 class="text-lg font-bold text-navy-800">Materias</h2>
      <p class="text-sm text-navy-500"><span id="contador">0</span> materias en el catálogo</p>
    </div>
    <button id="btn-nuevo" class="flex items-center gap-2 rounded-lg bg-navy-700 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-navy-800">
      <i class="fa-solid fa-plus"></i>
      Nueva materia
    </button>
  </div>

  <div class="overflow-hidden rounded-xl border border-navy-100 bg-white">
    <table class="w-full text-left text-sm">
      <thead class="bg-navy-50 text-xs uppercase tracking-wide text-navy-500">
        <tr>
          <th class="px-4 py-3 font-semibold">Materia</th>
          <th class="px-4 py-3 font-semibold text-center">Notas registradas</th>
          <th class="px-4 py-3 text-right font-semibold">Acciones</th>
        </tr>
      </thead>
      <tbody id="tabla" class="divide-y divide-navy-100"></tbody>
    </table>
    <div id="vacio" class="hidden px-4 py-12 text-center text-navy-400">
      <i class="fa-solid fa-book mb-2 text-3xl"></i>
      <p class="text-sm">Aún no hay materias. Agrega la primera.</p>
    </div>
  </div>

  <!-- Modal -->
  <div id="modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-navy-900/50 p-4">
    <div class="w-full max-w-md rounded-2xl bg-white shadow-2xl">
      <div class="flex items-center justify-between border-b border-navy-100 px-6 py-4">
        <h3 id="modal-titulo" class="text-base font-semibold text-navy-800">Nueva materia</h3>
        <button id="btn-cerrar" class="text-navy-400 transition hover:text-navy-700"><i class="fa-solid fa-xmark text-lg"></i></button>
      </div>

      <form id="form" class="space-y-4 px-6 py-5">
        <input type="hidden" id="f-id" />
        <div>
          <label class="mb-1 block text-sm font-medium text-navy-700">Nombre de la materia</label>
          <input id="f-nombre" type="text" required placeholder="Ej. Matemáticas" class="w-full rounded-lg border border-navy-200 px-3 py-2 text-sm outline-none focus:border-navy-500 focus:ring-2 focus:ring-navy-200" />
        </div>

        <p id="form-error" class="hidden rounded-lg bg-rose-50 px-3 py-2 text-sm text-rose-700"></p>

        <div class="flex justify-end gap-3 pt-2">
          <button type="button" id="btn-cancelar" class="rounded-lg border border-navy-200 px-4 py-2 text-sm font-medium text-navy-700 transition hover:bg-navy-50">Cancelar</button>
          <button type="submit" class="flex items-center gap-2 rounded-lg bg-navy-700 px-4 py-2 text-sm font-semibold text-white transition hover:bg-navy-800">
            <i class="fa-solid fa-floppy-disk"></i> Guardar
          </button>
        </div>
      </form>
    </div>
  </div>
</DashboardLayout>

<script>
  import { apiFetch } from '../lib/auth.js';

  const $ = (id) => document.getElementById(id);
  const modal = $('modal');

  let materias = [];

  async function refrescar() {
    materias = await apiFetch('/materias').then((r) => r.json());
    $('contador').textContent = materias.length;
    const tbody = $('tabla');
    tbody.innerHTML = '';
    if (materias.length === 0) { $('vacio').classList.remove('hidden'); return; }
    $('vacio').classList.add('hidden');

    for (const m of materias) {
      const tr = document.createElement('tr');
      tr.className = 'hover:bg-navy-50';
      tr.innerHTML = `
        <td class="px-4 py-3">
          <div class="flex items-center gap-3">
            <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-navy-50 text-navy-700"><i class="fa-solid fa-book"></i></div>
            <span class="font-medium text-navy-800">${m.nombre}</span>
          </div>
        </td>
        <td class="px-4 py-3 text-center text-navy-600">${m.notas_count}</td>
        <td class="px-4 py-3">
          <div class="flex justify-end gap-1">
            <button data-accion="editar" data-id="${m.id}" class="flex h-8 w-8 items-center justify-center rounded-lg text-navy-500 transition hover:bg-navy-100 hover:text-navy-700" title="Editar"><i class="fa-solid fa-pen pointer-events-none"></i></button>
            <button data-accion="eliminar" data-id="${m.id}" class="flex h-8 w-8 items-center justify-center rounded-lg text-rose-500 transition hover:bg-rose-50" title="Eliminar"><i class="fa-solid fa-trash pointer-events-none"></i></button>
          </div>
        </td>`;
      tbody.appendChild(tr);
    }
  }

  function abrirModal(m = null) {
    $('form-error').classList.add('hidden');
    $('form').reset();
    if (m) {
      $('modal-titulo').textContent = 'Editar materia';
      $('f-id').value = m.id;
      $('f-nombre').value = m.nombre;
    } else {
      $('modal-titulo').textContent = 'Nueva materia';
      $('f-id').value = '';
    }
    modal.classList.remove('hidden');
    modal.classList.add('flex');
  }
  function cerrarModal() { modal.classList.add('hidden'); modal.classList.remove('flex'); }

  async function guardar(e) {
    e.preventDefault();
    $('form-error').classList.add('hidden');
    const id = $('f-id').value;
    const datos = { nombre: $('f-nombre').value };
    const url = id ? `/materias/${id}` : '/materias';
    const res = await apiFetch(url, {
      method: id ? 'PUT' : 'POST',
      body: JSON.stringify(datos),
    });
    if (res.ok) { cerrarModal(); refrescar(); }
    else {
      const err = await res.json();
      const msg = err.errors ? Object.values(err.errors).flat().join(' ') : (err.message ?? 'Error al guardar.');
      $('form-error').textContent = msg;
      $('form-error').classList.remove('hidden');
    }
  }

  async function eliminar(id) {
    if (!confirm('¿Eliminar esta materia?')) return;
    const res = await apiFetch(`/materias/${id}`, { method: 'DELETE' });
    if (res.ok) { refrescar(); }
    else { const err = await res.json(); alert(err.message ?? 'No se pudo eliminar.'); }
  }

  $('btn-nuevo').addEventListener('click', () => abrirModal());
  $('btn-cerrar').addEventListener('click', cerrarModal);
  $('btn-cancelar').addEventListener('click', cerrarModal);
  $('form').addEventListener('submit', guardar);
  modal.addEventListener('click', (e) => { if (e.target === modal) cerrarModal(); });
  $('tabla').addEventListener('click', (e) => {
    const btn = e.target.closest('button[data-accion]');
    if (!btn) return;
    const id = Number(btn.dataset.id);
    if (btn.dataset.accion === 'eliminar') eliminar(id);
    else abrirModal(materias.find((m) => m.id === id));
  });

  refrescar();
</script>
